                        "old_best_ask",
                        "new_best_ask",
                        "ask_move_10m_pp",
                        "direction",
                        "live",
                        "ended",
                    ]
                )
            writer.writerow(
                [
                    scanned_at,
                    ref.sport,
                    ref.league,
