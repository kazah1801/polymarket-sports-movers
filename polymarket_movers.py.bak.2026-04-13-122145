    ) -> None:
        logging.info(
            "Universe debug: raw sports-tagged events=%s | deduped events=%s | raw markets=%s | after date window=%s | after exclude live/ended/started/closed=%s | after moneyline=%s | tracked outcomes=%s",
            raw_events,
            deduped_events,
            raw_markets,
            date_window_events,
